# ─────────────────────────────────────────────────────────────
#  Vaani POC — Universal Coaching App (ISOLATED from the real DB)
#  Copy to .env.poc.  Never points at public_speaking_intelligence.
# ─────────────────────────────────────────────────────────────

# Isolated mock MongoDB (vaani_poc_mongo on host port 27018, no auth)
POC_MONGO_URI=mongodb://localhost:27018
POC_MONGO_DB=public_speaking_intelligence_mock

# FastAPI backend
POC_API_HOST=0.0.0.0
POC_API_PORT=8090
POC_CORS_ORIGINS=*

# Object storage: localfs | minio  (audio is NEVER stored in Mongo)
OBJECT_STORE=localfs
POC_STORAGE_DIR=./.poc-storage
# MinIO (only when OBJECT_STORE=minio; start: docker compose -f docker-compose.poc.yml --profile storage up -d)
POC_MINIO_ENDPOINT=http://localhost:9000
POC_MINIO_USER=vaani_poc
POC_MINIO_PASS=vaani_poc_secret
POC_MINIO_BUCKET=vaani-poc-audio

# AI providers: mock | <real provider id>  (mock = deterministic, no cloud creds)
PROVIDER_STT=mock
PROVIDER_TTS=mock
PROVIDER_LLM=mock

LOG_LEVEL=INFO

# ─────────────────────────────────────────────────────────────
#  Vaani POC — Universal Coaching App (ISOLATED from the real DB)
#  Copy to .env.poc.  Never points at public_speaking_intelligence.
# ─────────────────────────────────────────────────────────────

# Isolated mock MongoDB (vaani_poc_mongo on host port 27018, no auth)
POC_MONGO_URI=mongodb://localhost:27018
POC_MONGO_DB=public_speaking_intelligence_mock

# FastAPI backend
POC_API_HOST=0.0.0.0
POC_API_PORT=8090
POC_CORS_ORIGINS=*

# Object storage: localfs | minio  (audio is NEVER stored in Mongo)
OBJECT_STORE=localfs
POC_STORAGE_DIR=./.poc-storage
# MinIO (only when OBJECT_STORE=minio; start: docker compose -f docker-compose.poc.yml --profile storage up -d)
POC_MINIO_ENDPOINT=http://localhost:9000
POC_MINIO_USER=vaani_poc
POC_MINIO_PASS=vaani_poc_secret
POC_MINIO_BUCKET=vaani-poc-audio

# AI providers (mock = deterministic, no cloud creds — the default + what CI uses).
#   PROVIDER_STT: mock | whisper   (whisper = local faster-whisper, no API key;
#                                   install services/api/requirements-local.txt first)
#   PROVIDER_TTS: mock | macos     (macos = macOS `say`, real voice, macOS only)
#   PROVIDER_LLM: mock             (only deterministic feedback in the POC)
PROVIDER_STT=mock
PROVIDER_TTS=mock
PROVIDER_LLM=mock

# Real-provider tuning (used only when the matching PROVIDER_* is non-mock).
POC_WHISPER_MODEL=base.en       # tiny.en | base.en | small.en | …
POC_WHISPER_DEVICE=cpu
POC_WHISPER_COMPUTE=int8
POC_TTS_VOICE=                  # blank → system default voice (e.g. Samantha, Daniel)
POC_TTS_RATE=0                  # 0 → system default words-per-minute

LOG_LEVEL=INFO

{
  "$jsonSchema": {
    "bsonType": "object",
    "required": ["event_id", "event_type", "created_at", "schema_version"],
    "additionalProperties": true,
    "properties": {
      "_id":            { "bsonType": "objectId" },
      "event_id":       { "bsonType": "string", "minLength": 1 },
      "event_type":     { "bsonType": "string", "minLength": 1 },
      "session_id":     { "bsonType": ["string", "null"] },
      "severity":       { "bsonType": "string", "enum": ["info", "warn", "error"] },
      "latency_ms":     { "bsonType": ["int", "null"], "minimum": 0 },
      "success":        { "bsonType": ["bool", "null"] },
      "payload":        { "bsonType": "object" },
      "created_at":     { "bsonType": "date" },
      "updated_at":     { "bsonType": "date" },
      "schema_version": { "bsonType": "string" }
    }
  }
}

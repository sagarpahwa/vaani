{
  "$jsonSchema": {
    "bsonType": "object",
    "required": ["session_id", "user_id", "mode", "status", "created_at", "schema_version"],
    "additionalProperties": true,
    "properties": {
      "_id":                      { "bsonType": "objectId" },
      "session_id":               { "bsonType": "string", "minLength": 1 },
      "user_id":                  { "bsonType": "string", "minLength": 1 },
      "mode":                     { "bsonType": "string", "enum": ["guided", "user_script", "persona"] },
      "script_id":                { "bsonType": ["string", "null"] },
      "user_script_text":         { "bsonType": ["string", "null"] },
      "goal_signature": {
        "bsonType": "object",
        "properties": {
          "objective":        { "bsonType": "string" },
          "occasion":         { "bsonType": "string" },
          "audience":         { "bsonType": "string" },
          "style":            { "bsonType": "string" },
          "language":         { "bsonType": "string" },
          "duration_seconds": { "bsonType": ["int", "null"] }
        }
      },
      "status":                   { "bsonType": "string", "enum": ["created", "recording", "processing", "scored", "failed"] },
      "attempt":                  { "bsonType": "int", "minimum": 1 },
      "parent_session_id":        { "bsonType": ["string", "null"] },
      "overall_score":            { "bsonType": ["double", "null"], "minimum": 0, "maximum": 1 },
      "capability_scores":        { "bsonType": ["object", "null"] },
      "rubric_version":           { "bsonType": ["string", "null"] },
      "scoring_model_version":    { "bsonType": ["string", "null"] },
      "feature_extractor_version":{ "bsonType": ["string", "null"] },
      "prompt_version":           { "bsonType": ["string", "null"] },
      "error":                    { "bsonType": ["string", "null"] },
      "created_at":               { "bsonType": "date" },
      "updated_at":               { "bsonType": "date" },
      "schema_version":           { "bsonType": "string" }
    }
  }
}

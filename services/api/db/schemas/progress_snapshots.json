{
  "$jsonSchema": {
    "bsonType": "object",
    "required": ["snapshot_id", "user_id", "created_at", "schema_version"],
    "additionalProperties": true,
    "properties": {
      "_id":               { "bsonType": "objectId" },
      "snapshot_id":       { "bsonType": "string", "minLength": 1 },
      "user_id":           { "bsonType": "string", "minLength": 1 },
      "session_id":        { "bsonType": ["string", "null"] },
      "overall_score":     { "bsonType": ["double", "null"], "minimum": 0, "maximum": 1 },
      "capability_scores": { "bsonType": "object" },
      "delta_vs_previous": { "bsonType": ["object", "null"] },
      "created_at":        { "bsonType": "date" },
      "updated_at":        { "bsonType": "date" },
      "schema_version":    { "bsonType": "string" }
    }
  }
}

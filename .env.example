# ─────────────────────────────────────────────
#  Vaani — Public Speaking Intelligence Platform
#  Copy this file to .env and fill in values
# ─────────────────────────────────────────────

# MongoDB local (Docker)
MONGO_ROOT_USER=vaani_admin
MONGO_ROOT_PASS=vaani_secret
MONGO_DB=public_speaking_intelligence
MONGO_URI=mongodb://vaani_admin:vaani_secret@localhost:27017/public_speaking_intelligence?authSource=admin

# MongoDB Atlas (Phase 2 — optional)
# MONGO_ATLAS_URI=mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/public_speaking_intelligence

# Python pipeline
LOG_LEVEL=INFO
WIKIDATA_SPARQL_ENDPOINT=https://query.wikidata.org/sparql
WIKIDATA_USER_AGENT=Vaani/1.0 (public-speaking-intelligence; contact@vaani.ai)

# Rate limiting
WIKIDATA_REQUEST_DELAY_SECONDS=1.5
MAX_CANDIDATES_PER_RUN=10000

# Export
EXPORT_DIR=./exports
